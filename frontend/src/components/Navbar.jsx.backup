// src/component/Navbar.jsx
import React, { useState, useEffect, useRef } from 'react';
import { useNavigate, useLocation } from 'react-router-dom';
import {
  Shield,
  Search,
  Bell,
  User,
  LogOut,
  Settings,
  UserCircle,
  Menu,
  X,
  ChevronDown,
  LayoutDashboard,
  Radar,
  Camera,
  AlertTriangle,
  Users,
  MapPin,
  HelpCircle,
  Plus,
  Sparkles,
  Moon,
  Sun,
  Activity,
} from 'lucide-react';

const Navbar = () => {
  const navigate = useNavigate();
  const location = useLocation();
  const [isScrolled, setIsScrolled] = useState(false);
  const [showProfileMenu, setShowProfileMenu] = useState(false);
  const [showMobileMenu, setShowMobileMenu] = useState(false);
  const [isDark, setIsDark] = useState(true);
  const [searchFocused, setSearchFocused] = useState(false);
  const [searchQuery, setSearchQuery] = useState('');
  const profileMenuRef = useRef(null);
  const mobileMenuRef = useRef(null);
  const searchRef = useRef(null);

  // ─── User data ──────────────────────────────────────────────────
  const isLoggedIn = false;
  const user = {
    name: 'Alex Rivera',
    email: 'alex@tracepoint.io',
    role: 'Lead Investigator',
    initials: 'AR',
    notifications: 3,
  };

  // ─── Navigation items ──────────────────────────────────────────
  const navItems = [
    { label: 'Home', href: '/' },
    { label: 'Services', href: '/services' },
    { label: 'Features', href: '/features' },
    { label: 'About', href: '/about' },
  ];

  // ─── Click outside handlers ────────────────────────────────────
  useEffect(() => {
    const handleClickOutside = (event) => {
      if (profileMenuRef.current && !profileMenuRef.current.contains(event.target)) {
        setShowProfileMenu(false);
      }
      if (mobileMenuRef.current && !mobileMenuRef.current.contains(event.target)) {
        setShowMobileMenu(false);
      }
      if (searchRef.current && !searchRef.current.contains(event.target)) {
        setSearchFocused(false);
      }
    };
    document.addEventListener('mousedown', handleClickOutside);
    return () => document.removeEventListener('mousedown', handleClickOutside);
  }, []);

  // ─── Scroll handler ────────────────────────────────────────────
  useEffect(() => {
    const handleScroll = () => {
      setIsScrolled(window.scrollY > 20);
    };
    window.addEventListener('scroll', handleScroll);
    return () => window.removeEventListener('scroll', handleScroll);
  }, []);

  // ─── Keyboard shortcut ────────────────────────────────────────
  useEffect(() => {
    const handleKeyDown = (e) => {
      if ((e.ctrlKey || e.metaKey) && e.key === 'k') {
        e.preventDefault();
        document.getElementById('global-search')?.focus();
      }
    };
    document.addEventListener('keydown', handleKeyDown);
    return () => document.removeEventListener('keydown', handleKeyDown);
  }, []);

  // ─── Dark mode toggle ──────────────────────────────────────────
  const toggleDarkMode = () => {
    setIsDark(!isDark);
    document.documentElement.classList.toggle('dark');
  };

  // ─── Handlers ──────────────────────────────────────────────────
  const handleLogout = () => {
    localStorage.removeItem('token');
    localStorage.removeItem('user');
    navigate('/login');
  };

  const handleProfile = () => {
    navigate('/profile');
    setShowProfileMenu(false);
  };

  const handleSettings = () => {
    navigate('/settings');
    setShowProfileMenu(false);
  };

  const isActive = (href) => location.pathname === href;

  return (
    <>
      <style>{`
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500;600&display=swap');
        
        .font-display {
          font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
          font-weight: 800;
          letter-spacing: -0.02em;
        }
        .font-mono-cw {
          font-family: 'JetBrains Mono', monospace;
        }

        @keyframes slideDown {
          from { opacity: 0; transform: translateY(-8px) scale(0.98); }
          to { opacity: 1; transform: translateY(0) scale(1); }
        }
        @keyframes slideUp {
          from { opacity: 0; transform: translateY(8px) scale(0.98); }
          to { opacity: 1; transform: translateY(0) scale(1); }
        }
        @keyframes pulse-ring {
          0% { transform: scale(0.8); opacity: 0.8; }
          100% { transform: scale(1.6); opacity: 0; }
        }
        
        .animate-slide-down { animation: slideDown 0.15s ease-out; }
        .animate-slide-up { animation: slideUp 0.15s ease-out; }
        .animate-pulse-ring { animation: pulse-ring 1.5s cubic-bezier(0.4, 0, 0.2, 1) infinite; }
        
        .glass {
          background: rgba(10, 15, 30, 0.75);
          backdrop-filter: blur(20px) saturate(1.4);
          -webkit-backdrop-filter: blur(20px) saturate(1.4);
        }
        .glass-light {
          background: rgba(255, 255, 255, 0.7);
          backdrop-filter: blur(20px) saturate(1.4);
          -webkit-backdrop-filter: blur(20px) saturate(1.4);
        }
        .dark .glass-light { background: rgba(10, 15, 30, 0.85); }
        
        .glass-border {
          border: 1px solid rgba(255, 255, 255, 0.06);
        }
        .glass-border-light {
          border: 1px solid rgba(0, 0, 0, 0.05);
        }
        
        .nav-item {
          position: relative;
          transition: all 0.2s ease;
          font-weight: 500;
        }
        .nav-item::after {
          content: '';
          position: absolute;
          bottom: 0;
          left: 50%;
          width: 0;
          height: 2px;
          background: linear-gradient(90deg, #10b981, #059669);
          transform: translateX(-50%);
          transition: width 0.3s ease;
          border-radius: 2px;
        }
        .nav-item.active::after {
          width: 60%;
        }
        .nav-item:hover::after {
          width: 40%;
        }
        
        .search-container {
          transition: all 0.3s ease;
        }
        .search-container:focus-within {
          transform: scale(1.02);
          border-color: #10b981;
          box-shadow: 0 0 0 3px rgba(16, 185, 129, 0.15);
        }
        
        .status-dot {
          position: relative;
        }
        .status-dot::before {
          content: '';
          position: absolute;
          inset: -3px;
          border-radius: 50%;
          background: rgba(16, 185, 129, 0.3);
          animation: pulse-ring 1.5s cubic-bezier(0.4, 0, 0.2, 1) infinite;
        }
      `}</style>

      <nav
        className={`fixed top-0 left-0 right-0 z-50 h-16 transition-all duration-300 ${
          isScrolled
            ? isDark
              ? 'glass glass-border border-b border-white/5 shadow-2xl shadow-black/20'
              : 'glass-light glass-border-light border-b border-gray-200/50 shadow-lg shadow-gray-200/30'
            : isDark
            ? 'bg-transparent border-b border-white/5'
            : 'bg-transparent border-b border-gray-200/20'
        }`}
      >
        <div className="h-full px-4 sm:px-6 flex items-center justify-between max-w-screen-2xl mx-auto">
          {/* ─── Left: Logo + Brand ─────────────────────────────── */}
          <div className="flex items-center gap-3">
            <button
              onClick={() => navigate('/')}
              className="flex items-center gap-2.5 group"
            >
              <div className="relative">
                <div className="w-9 h-9 rounded-xl bg-gradient-to-br from-green-600 to-emerald-600 flex items-center justify-center shadow-lg shadow-green-500/20 group-hover:shadow-green-500/40 transition-shadow duration-300">
                  <Shield className="w-4.5 h-4.5 text-white" strokeWidth={2.5} />
                </div>
                <div className="absolute -top-0.5 -right-0.5 w-2.5 h-2.5 rounded-full bg-emerald-400 border-2 border-white dark:border-slate-900 animate-pulse" />
              </div>
              <div className="hidden sm:block">
                <span className={`font-display text-lg font-extrabold tracking-tight ${isDark ? 'text-white' : 'text-slate-900'}`}>
                  Trace<span className="text-green-500 dark:text-green-400">Point</span>
                </span>
                <span className="ml-1.5 text-[10px] font-mono-cw font-medium text-slate-400 dark:text-slate-500 uppercase tracking-widest">
                  Platform
                </span>
              </div>
            </button>

            {/* ─── Live status badge ────────────────────────────── */}
            <div className="hidden md:flex items-center gap-2 px-3.5 py-1.5 rounded-full bg-emerald-500/10 dark:bg-emerald-500/20 border border-emerald-500/20 dark:border-emerald-500/30">
              <div className="relative">
                <div className="w-1.5 h-1.5 rounded-full bg-emerald-500 animate-pulse" />
                <div className="absolute inset-0 rounded-full bg-emerald-500/30 animate-pulse-ring" />
              </div>
              <span className="text-xs font-semibold text-emerald-600 dark:text-emerald-400">
                12 active cases
              </span>
            </div>
          </div>

          {/* ─── Center: Navigation ──────────────────────────────── */}
          <div className="hidden lg:flex items-center gap-0.5">
            {navItems.map((item) => (
              <a
                key={item.label}
                href={item.href}
                onClick={(e) => {
                  e.preventDefault();
                  navigate(item.href);
                }}
                className={`nav-item px-4 py-2 text-sm ${
                  isActive(item.href)
                    ? 'active text-green-500 dark:text-green-400'
                    : isDark
                    ? 'text-slate-300 hover:text-white'
                    : 'text-slate-600 hover:text-slate-900'
                }`}
              >
                {item.label}
              </a>
            ))}
          </div>

          {/* ─── Right: Search + Actions ────────────────────────── */}
          <div className="flex items-center gap-1.5">
            {/* ─── Search bar ─────────────────────────────────────── */}
            <div
              ref={searchRef}
              className="hidden md:flex relative flex-1 max-w-xs lg:max-w-sm"
            >
              <div
                className={`search-container w-full flex items-center gap-2.5 px-3.5 py-1.5 rounded-xl transition-all duration-300 ${
                  searchFocused
                    ? 'ring-2 ring-green-500/40 dark:ring-green-400/40 shadow-lg shadow-green-500/10 dark:shadow-green-400/10 border-green-500/40'
                    : `border ${isDark ? 'border-white/10 hover:border-white/20' : 'border-gray-200/50 hover:border-gray-300'}`
                } ${isDark ? 'bg-white/5' : 'bg-white/50'} backdrop-blur-sm`}
              >
                <Search className="w-4 h-4 text-slate-400 flex-shrink-0" />
                <input
                  id="global-search"
                  type="text"
                  placeholder="Search cases, people..."
                  value={searchQuery}
                  onChange={(e) => setSearchQuery(e.target.value)}
                  onFocus={() => setSearchFocused(true)}
                  onBlur={() => setSearchFocused(false)}
                  className={`w-full bg-transparent outline-none text-sm placeholder:text-sm ${
                    isDark ? 'text-white placeholder:text-slate-500' : 'text-slate-700 placeholder:text-slate-400'
                  }`}
                />
                <div className="flex items-center gap-1 flex-shrink-0">
                  <kbd className="hidden sm:inline-flex items-center px-1.5 py-0.5 text-[10px] font-mono-cw font-medium text-slate-400 dark:text-slate-500 bg-slate-100/50 dark:bg-slate-700/50 rounded border border-slate-200 dark:border-slate-600">
                    ⌘
                  </kbd>
                  <kbd className="hidden sm:inline-flex items-center px-1.5 py-0.5 text-[10px] font-mono-cw font-medium text-slate-400 dark:text-slate-500 bg-slate-100/50 dark:bg-slate-700/50 rounded border border-slate-200 dark:border-slate-600">
                    K
                  </kbd>
                </div>
              </div>
            </div>

            {/* ─── Report CTA ────────────────────────────────────── */}
            <button
              onClick={() => navigate('/report')}
              className="hidden lg:flex items-center gap-2 px-4 py-1.5 rounded-full bg-gradient-to-r from-green-600 to-emerald-600 text-white text-sm font-semibold hover:shadow-lg hover:shadow-green-500/30 transition-all duration-300 transform hover:scale-[1.02]"
            >
              <Plus className="w-4 h-4" />
              Report
            </button>

            {/* ─── Dark mode toggle ────────────────────────────── */}
            <button
              onClick={toggleDarkMode}
              className="hidden sm:flex items-center justify-center w-9 h-9 rounded-xl hover:bg-white/5 transition-colors text-slate-400 hover:text-white"
              aria-label="Toggle dark mode"
            >
              {isDark ? <Sun className="w-4.5 h-4.5" /> : <Moon className="w-4.5 h-4.5" />}
            </button>

            {/* ─── Notifications ─────────────────────────────────── */}
            <button className="relative flex items-center justify-center w-9 h-9 rounded-xl hover:bg-white/5 transition-colors text-slate-400 hover:text-white">
              <Bell className="w-4.5 h-4.5" />
              {isLoggedIn && user.notifications > 0 && (
                <>
                  <span className="absolute -top-0.5 -right-0.5 w-4 h-4 rounded-full bg-red-500 text-white text-[9px] font-bold flex items-center justify-center shadow-lg shadow-red-500/30">
                    {user.notifications}
                  </span>
                  <span className="absolute inset-0 rounded-xl animate-pulse-ring border border-red-500/30" />
                </>
              )}
            </button>

            {/* ─── Auth / Profile ────────────────────────────────── */}
            {isLoggedIn ? (
              <div className="relative" ref={profileMenuRef}>
                <button
                  onClick={() => setShowProfileMenu(!showProfileMenu)}
                  className={`flex items-center gap-2 p-1.5 pr-2.5 rounded-xl transition-all duration-200 ${
                    showProfileMenu
                      ? 'bg-green-500/10 dark:bg-white/10 ring-1 ring-green-500/20 dark:ring-green-400/20'
                      : 'hover:bg-white/5'
                  }`}
                >
                  <div className="relative flex-shrink-0">
                    <div className="w-8 h-8 rounded-full bg-gradient-to-br from-green-600 to-emerald-700 flex items-center justify-center text-white font-display font-semibold text-xs shadow-lg shadow-green-500/20">
                      {user.initials}
                    </div>
                    <div className="status-dot absolute -bottom-0.5 -right-0.5 w-2.5 h-2.5 rounded-full bg-emerald-500 border-2 border-white dark:border-slate-900" />
                  </div>
                  <div className="hidden sm:block text-left">
                    <p className="text-sm font-medium text-white leading-tight">
                      {user.name}
                    </p>
                    <p className="text-[10px] font-mono-cw text-slate-400 leading-tight">
                      {user.role}
                    </p>
                  </div>
                  <ChevronDown
                    className={`w-4 h-4 text-slate-400 transition-transform duration-200 ${
                      showProfileMenu ? 'rotate-180' : ''
                    }`}
                  />
                </button>

                {showProfileMenu && (
                  <div className="absolute right-0 mt-2 w-72 bg-slate-900/95 backdrop-blur-xl rounded-2xl shadow-2xl border border-white/10 py-2 animate-slide-up overflow-hidden">
                    <div className="px-4 py-3 border-b border-white/10">
                      <div className="flex items-center gap-3">
                        <div className="w-10 h-10 rounded-full bg-gradient-to-br from-green-600 to-emerald-700 flex items-center justify-center text-white font-display font-semibold text-sm shadow-lg shadow-green-500/20">
                          {user.initials}
                        </div>
                        <div>
                          <p className="text-sm font-semibold text-white">{user.name}</p>
                          <p className="text-xs text-slate-400">{user.email}</p>
                        </div>
                      </div>
                    </div>

                    <div className="py-1">
                      <button
                        onClick={handleProfile}
                        className="flex items-center gap-3 w-full px-4 py-2.5 text-sm text-slate-300 hover:bg-white/5 transition-colors group"
                      >
                        <UserCircle className="w-4 h-4 text-slate-400 group-hover:text-green-400 transition-colors" />
                        <span>Profile</span>
                        <span className="ml-auto text-[10px] text-slate-500 font-mono-cw">⌘P</span>
                      </button>
                      <button
                        onClick={handleSettings}
                        className="flex items-center gap-3 w-full px-4 py-2.5 text-sm text-slate-300 hover:bg-white/5 transition-colors group"
                      >
                        <Settings className="w-4 h-4 text-slate-400 group-hover:text-green-400 transition-colors" />
                        <span>Settings</span>
                        <span className="ml-auto text-[10px] text-slate-500 font-mono-cw">⌘S</span>
                      </button>
                    </div>

                    <hr className="my-1 border-white/10" />

                    <button
                      onClick={handleLogout}
                      className="flex items-center gap-3 w-full px-4 py-2.5 text-sm text-red-400 hover:bg-red-500/10 transition-colors group"
                    >
                      <LogOut className="w-4 h-4 group-hover:scale-110 transition-transform" />
                      <span>Logout</span>
                      <span className="ml-auto text-[10px] text-slate-500 font-mono-cw">⌘Q</span>
                    </button>
                  </div>
                )}
              </div>
            ) : (
              <div className="flex items-center gap-2">
                <button
                  onClick={() => navigate('/login')}
                  className={`text-sm font-medium ${isDark ? 'text-slate-300 hover:text-white' : 'text-slate-600 hover:text-slate-900'} transition-colors`}
                >
                  Login
                </button>
                <button
                  onClick={() => navigate('/register')}
                  className={`px-4 py-1.5 rounded-full text-sm font-semibold transition-all duration-300 ${
                    isDark
                      ? 'bg-white text-slate-900 hover:bg-white/90'
                      : 'bg-slate-900 text-white hover:bg-slate-800'
                  }`}
                >
                  Register
                </button>
              </div>
            )}

            {/* ─── Mobile menu toggle ────────────────────────────── */}
            <button
              onClick={() => setShowMobileMenu(!showMobileMenu)}
              className="lg:hidden flex items-center justify-center w-9 h-9 rounded-xl hover:bg-white/5 transition-colors text-slate-400 hover:text-white"
              aria-label="Toggle menu"
            >
              {showMobileMenu ? <X className="w-5 h-5" /> : <Menu className="w-5 h-5" />}
            </button>
          </div>
        </div>
      </nav>

      {/* ─── Mobile menu ────────────────────────────────────────── */}
      {showMobileMenu && (
        <div
          className="fixed inset-0 z-40 bg-black/60 backdrop-blur-sm lg:hidden"
          onClick={() => setShowMobileMenu(false)}
        />
      )}

      <div
        ref={mobileMenuRef}
        className={`fixed top-16 left-0 right-0 z-40 bg-slate-900/95 backdrop-blur-xl border-b border-white/10 shadow-2xl lg:hidden transition-all duration-300 ${
          showMobileMenu
            ? 'opacity-100 translate-y-0'
            : 'opacity-0 -translate-y-4 pointer-events-none'
        }`}
      >
        <div className="p-4 space-y-1 max-h-[calc(100vh-4rem)] overflow-y-auto">
          <div className="relative mb-4">
            <Search className="absolute left-3 top-1/2 transform -translate-y-1/2 w-4 h-4 text-slate-400" />
            <input
              type="text"
              placeholder="Search cases, people..."
              className="w-full pl-10 pr-4 py-2.5 bg-slate-800/50 border border-white/10 rounded-xl text-sm text-white placeholder:text-slate-500 focus:outline-none focus:ring-2 focus:ring-green-500 focus:border-transparent"
            />
          </div>

          <button
            onClick={() => {
              navigate('/report');
              setShowMobileMenu(false);
            }}
            className="flex items-center justify-center gap-2 w-full py-2.5 rounded-xl bg-gradient-to-r from-green-600 to-emerald-600 text-white text-sm font-semibold mb-3"
          >
            <Plus className="w-4 h-4" />
            Report a Missing Person
          </button>

          <hr className="my-2 border-white/10" />

          {navItems.map((item) => (
            <a
              key={item.label}
              href={item.href}
              onClick={(e) => {
                e.preventDefault();
                navigate(item.href);
                setShowMobileMenu(false);
              }}
              className={`flex items-center w-full px-4 py-3 rounded-xl text-sm font-medium transition-all ${
                isActive(item.href)
                  ? 'bg-green-500/10 text-green-400'
                  : 'text-slate-300 hover:bg-white/5'
              }`}
            >
              {item.label}
            </a>
          ))}

          <hr className="my-2 border-white/10" />

          <button
            onClick={() => {
              navigate('/services');
              setShowMobileMenu(false);
            }}
            className="flex items-center w-full px-4 py-3 rounded-xl text-sm font-medium text-slate-300 hover:bg-white/5 transition-all"
          >
            Services
          </button>
          <button
            onClick={() => {
              navigate('/features');
              setShowMobileMenu(false);
            }}
            className="flex items-center w-full px-4 py-3 rounded-xl text-sm font-medium text-slate-300 hover:bg-white/5 transition-all"
          >
            Features
          </button>

          <hr className="my-2 border-white/10" />

          {!isLoggedIn ? (
            <div className="flex flex-col gap-2 pt-2">
              <button
                onClick={() => {
                  navigate('/login');
                  setShowMobileMenu(false);
                }}
                className="flex items-center justify-center w-full py-2.5 rounded-xl text-sm font-medium text-white bg-white/10 hover:bg-white/20 transition-all"
              >
                Login
              </button>
              <button
                onClick={() => {
                  navigate('/register');
                  setShowMobileMenu(false);
                }}
                className="flex items-center justify-center w-full py-2.5 rounded-xl text-sm font-medium text-slate-900 bg-white hover:bg-white/90 transition-all"
              >
                Register
              </button>
            </div>
          ) : (
            <>
              <button
                onClick={handleProfile}
                className="flex items-center gap-3 w-full px-4 py-3 rounded-xl text-sm text-slate-300 hover:bg-white/5 transition-colors"
              >
                <UserCircle className="w-4 h-4 text-slate-400" />
                Profile
              </button>
              <button
                onClick={handleSettings}
                className="flex items-center gap-3 w-full px-4 py-3 rounded-xl text-sm text-slate-300 hover:bg-white/5 transition-colors"
              >
                <Settings className="w-4 h-4 text-slate-400" />
                Settings
              </button>
              <button
                onClick={handleLogout}
                className="flex items-center gap-3 w-full px-4 py-3 rounded-xl text-sm text-red-400 hover:bg-red-500/10 transition-colors"
              >
                <LogOut className="w-4 h-4" />
                Logout
              </button>
            </>
          )}
        </div>
      </nav>

      <div className="h-16" />
    </>
  );
};

export default Navbar;